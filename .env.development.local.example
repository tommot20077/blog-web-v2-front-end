# Copy this file to .env.development.local to override development defaults locally.
# .env.development.local is gitignored and will not be committed.

# Set to true to use mock data instead of a real backend (useful for UI-only development)
VITE_USE_MOCK=true

# Override the backend URL if your backend runs on a different port/host
# VITE_API_BASE_URL=http://localhost:8080
