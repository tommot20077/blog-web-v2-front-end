# Normalize text files to LF in the repository and working tree.
* text=auto eol=lf

# Windows command scripts conventionally use CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets should not be line-ending normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
